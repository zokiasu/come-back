{
	"name": "nuxt-app",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare && node scripts/ensure-vue-router-volar.cjs",
		"lint": "eslint . --fix",
		"lint:check": "eslint .",
		"lint:fix": "eslint . --fix --quiet && prettier --write \"**/*.{js,ts,vue,css,scss,json,md}\"",
		"format": "prettier --write \"**/*.{js,ts,vue,css,scss,json,md}\"",
		"format:check": "prettier --check \"**/*.{js,ts,vue,css,scss,json,md}\"",
		"typecheck": "node scripts/ensure-vue-router-volar.cjs && nuxi typecheck",
		"check": "npm run lint:check && npm run typecheck"
	},
	"devDependencies": {
		"@iconify-json/lucide": "^1.2.98",
		"@nuxt/devtools": "^3.2.3",
		"@nuxt/eslint": "^1.15.2",
		"@nuxt/hints": "^1.0.0",
		"@nuxt/image": "^2.0.0",
		"@types/node": "^25.5.0",
		"@types/web-push": "^3.6.4",
		"@vite-pwa/nuxt": "^1.1.1",
		"eslint": "^9.39.4",
		"nuxt": "^4.4.2",
		"picomatch": "^4.0.3",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"vue-tsc": "^3.2.5"
	},
	"dependencies": {
		"@nuxt/ui": "^4.5.1",
		"@nuxtjs/supabase": "^2.0.4",
		"@pinia/nuxt": "^0.11.3",
		"@supabase/supabase-js": "^2.99.1",
		"@tailwindcss/vite": "^4.2.1",
		"animate.css": "^4.1.1",
		"chart.js": "^4.5.1",
		"pinia": "^3.0.4",
		"pinia-plugin-persistedstate": "^4.7.1",
		"swiper": "^12.1.2",
		"tailwindcss": "^4.2.1",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vue": "^3.5.30",
		"vue-chartjs": "^5.3.3",
		"vuedraggable": "^4.1.0",
		"web-push": "^3.6.7",
		"workbox-cacheable-response": "^7.4.0",
		"workbox-expiration": "^7.4.0",
		"workbox-precaching": "^7.4.0",
		"workbox-routing": "^7.4.0",
		"workbox-strategies": "^7.4.0",
		"zod": "^4.3.6"
	}
