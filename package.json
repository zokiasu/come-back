{
	"name": "nuxt-app",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare && node scripts/ensure-vue-router-volar.cjs",
		"lint": "eslint . --fix",
		"lint:check": "eslint .",
		"lint:fix": "eslint . --fix --quiet && prettier --write \"**/*.{js,ts,vue,css,scss,json,md}\"",
		"format": "prettier --write \"**/*.{js,ts,vue,css,scss,json,md}\"",
		"format:check": "prettier --check \"**/*.{js,ts,vue,css,scss,json,md}\"",
		"test": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:run": "vitest run",
		"test:typecheck": "vue-tsc --noEmit -p tsconfig.test.json",
		"typecheck": "node scripts/ensure-vue-router-volar.cjs && nuxi typecheck",
		"check": "npm run lint:check && npm run typecheck && npm run test:typecheck && npm run test:run"
	},
	"devDependencies": {
		"@iconify-json/lucide": "^1.2.114",
		"@nuxt/devtools": "^3.2.3",
		"@nuxt/eslint": "^1.15.2",
		"@nuxt/hints": "^1.1.3",
		"@nuxt/image": "^2.0.0",
		"@nuxt/test-utils": "^4.0.3",
		"@types/node": "^25.5.0",
		"@types/web-push": "^3.6.4",
		"@vite-pwa/nuxt": "^1.1.1",
		"@vitest/coverage-v8": "^4.1.9",
		"@vue/test-utils": "^2.4.11",
		"eslint": "^10.5.0",
		"happy-dom": "^20.10.6",
		"nuxt": "^4.4.8",
		"picomatch": "^4.0.3",
		"prettier": "^3.8.4",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"vitest": "^4.1.9",
		"vue-tsc": "^3.3.5"
	},
	"dependencies": {
		"@nuxt/ui": "^4.9.0",
		"@nuxtjs/supabase": "^2.0.9",
		"@pinia/nuxt": "^0.11.3",
		"@supabase/supabase-js": "^2.108.2",
		"@tailwindcss/vite": "^4.3.1",
		"animate.css": "^4.1.1",
		"chart.js": "^4.5.1",
		"h3": "^1.15.11",
		"pinia": "^3.0.4",
		"pinia-plugin-persistedstate": "^4.7.1",
		"swiper": "^12.2.0",
		"tailwindcss": "^4.3.1",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"vue": "^3.5.38",
		"vue-chartjs": "^5.3.3",
		"vuedraggable": "^4.1.0",
		"web-push": "^3.6.7",
		"workbox-cacheable-response": "^7.4.1",
		"workbox-expiration": "^7.4.1",
		"workbox-precaching": "^7.4.1",
		"workbox-routing": "^7.4.1",
		"workbox-strategies": "^7.4.1",
		"zod": "^4.3.6"
	}
}
