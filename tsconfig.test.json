{
	"extends": "./.nuxt/tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		// "nuxt/app" exposes the Nuxt ImportMeta augmentation (import.meta.dev, etc.)
		// from node_modules without pulling the whole app component graph into the
		// test program (which an .nuxt/nuxt.d.ts include would do).
		"types": ["vitest/importMeta", "nuxt/app"]
	},
	"include": [
		"tests/**/*.ts",
		"server/utils/errorHandler.ts",
		"server/utils/queryFilters.ts",
		"server/utils/transformers.ts",
		"server/utils/validation.ts",
		"server/utils/youtubeMvMatcher.ts",
		"vitest.config.ts"
	]
}
