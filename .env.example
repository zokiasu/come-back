# =============================================================================
# Supabase
# =============================================================================
SUPABASE_URL=                          # URL du projet Supabase
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=  # Clé publishable (client, exposée au navigateur)
SUPABASE_SECRET_KEY=                   # Clé service role (SERVEUR UNIQUEMENT — bypass RLS, ne jamais exposer)
SUPABASE_ANON_KEY=                     # Clé anon (legacy, exposée dans runtimeConfig.public)

# =============================================================================
# YouTube Data API v3 (serveur uniquement — endpoints admin)
# =============================================================================
YOUTUBE_API_KEY=                       # Clé API YouTube Data v3

# =============================================================================
# Web Push (VAPID) — notifications push
# Générer : node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys(),null,2))"
# =============================================================================
VAPID_PUBLIC_KEY=                      # Clé publique VAPID (client)
VAPID_PRIVATE_KEY=                     # Clé privée VAPID (serveur)
VAPID_SUBJECT=mailto:admin@come-back.app  # Contact mailto: pour VAPID (défaut si vide)

# =============================================================================
# Cron
# =============================================================================
CRON_SECRET=                           # Secret Bearer des endpoints /api/cron/* (ex: openssl rand -hex 32)
